{
  "name": "koditor",
  "version": "0.1.1",
  "description": "Koditor - Web & Desktop Code Editor",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "dev:web": "vite",
    "dev:electron": "concurrently \"vite\" \"wait-on http://localhost:1420 && electron .\"",
    "build:web": "tsc && vite build",
    "build:electron": "cross-env ELECTRON=true vite build && electron-builder",
    "preview": "vite preview",
    "deploy": "npm run build:web && firebase deploy"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@monaco-editor/react": "^4.6.0",
    "electron-store": "^8.1.0",
    "iconv-lite": "^0.6.3",
    "firebase": "^10.12.0",
    "monaco-editor": "^0.45.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0",
    "cross-env": "^7.0.3"
  },
  "build": {
    "appId": "com.koditor.app",
    "productName": "Koditor",
    "directories": { "output": "release" },
    "files": ["dist/**/*", "electron/**/*"],
    "win": {
      "target": ["nsis"],
      "icon": "assets/icon.ico",
      "signingHashAlgorithms": null,
      "sign": null
    },
    "mac": {
      "target": ["dmg"],
      "icon": "assets/icon.icns",
      "category": "public.app-category.developer-tools",
      "identity": null
    },
    "linux": {
      "target": ["deb", "AppImage"],
      "icon": "assets/icon.png",
      "category": "Utility"
    }
  }
}